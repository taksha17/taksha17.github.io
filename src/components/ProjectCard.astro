---
const { title, year, tags, image, description } = Astro.props;
---
<div class="group relative flex flex-col cursor-pointer">
  <!-- Poster Container -->
  <div class="relative aspect-[2/3] w-full overflow-hidden rounded-md border border-white/5 bg-kiss-surface transition-all duration-300 group-hover:scale-105 group-hover:border-kiss-accent group-hover:shadow-[0_0_20px_rgba(255,46,81,0.3)] group-hover:z-10">
    <img src={image} alt={title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
    
    <!-- Gradient Overlay (Always there at bottom to make text readable) -->
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
    
    <!-- Plot Summary (Hidden until hover) -->
    <div class="absolute inset-0 p-4 flex flex-col justify-end translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
        <p class="text-xs text-gray-300 leading-relaxed drop-shadow-md">{description}</p>
    </div>

    <!-- Hover "Play" Icon (Center) -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 delay-100">
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-kiss-accent text-white shadow-lg scale-50 group-hover:scale-100 transition-transform duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
      </div>
    </div>
  </div>

  <!-- Meta Info (Below the poster) -->
  <div class="mt-3 px-1">
    <h3 class="truncate text-sm font-bold text-white group-hover:text-kiss-accent transition-colors">{title}</h3>
    <div class="flex flex-wrap items-center gap-2 mt-1 text-[10px] font-medium text-kiss-text-muted">
      <span>{year}</span>
      <span class="h-1 w-1 rounded-full bg-kiss-text-muted"></span>
      <span class="uppercase tracking-wider text-kiss-accent/80">{tags[0]}</span>
    </div>
  </div>
</div>