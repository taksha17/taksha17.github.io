---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';
---

<Layout title="Taksha Thosani | Applied AI Engineer">
  <main class="min-h-screen bg-kiss-bg text-white pb-24">
    
    <section class="relative min-h-[80vh] w-full overflow-hidden flex flex-col justify-center">
      <div class="absolute inset-0 bg-gradient-to-r from-kiss-bg via-kiss-bg/90 to-transparent z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-kiss-bg via-transparent to-transparent z-10"></div>
      <img src="https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?auto=format&fit=crop&w=1920&q=80" class="absolute inset-0 h-full w-full object-cover opacity-30" />
      
      <div class="relative z-20 px-8 md:px-16 pt-20">
        <span class="mb-2 inline-block text-sm font-bold tracking-widest text-kiss-accent uppercase">Applied AI Engineer</span>
        <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tight">TAKSHA THOSANI</h1>
        <p class="max-w-2xl text-lg text-gray-300 mb-8 leading-relaxed">
          Building production ML systems, real-time data platforms, and low-latency infrastructure. Experienced across personalization, forecasting, LLM-based systems, and large-scale event processing.
        </p>
        
        <div class="flex flex-wrap gap-4 mb-8">
          <a href="/Taksha Thosani_AI_.pdf" download class="flex items-center gap-2 rounded bg-kiss-accent px-8 py-3 text-white font-bold hover:bg-red-600 transition shadow-[0_0_20px_rgba(255,46,81,0.4)] hover:shadow-[0_0_30px_rgba(255,46,81,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Download Resume
          </a>
          <a href="https://github.com/taksha17" target="_blank" class="flex items-center gap-2 rounded bg-white/10 px-8 py-3 backdrop-blur-md font-bold hover:bg-white/20 transition border border-white/5">
            GitHub
          </a>
          <a href="https://linkedin.com/in/taksha-thosani" target="_blank" class="flex items-center gap-2 rounded bg-white/10 px-8 py-3 backdrop-blur-md font-bold hover:bg-white/20 transition border border-white/5">
            LinkedIn
          </a>
        </div>

        <div class="flex flex-wrap gap-2 text-xs font-semibold text-gray-300">
          <span class="border border-white/10 px-4 py-1.5 rounded-full bg-black/50 backdrop-blur-sm">Python / Rust / Go</span>
          <span class="border border-white/10 px-4 py-1.5 rounded-full bg-black/50 backdrop-blur-sm">PyTorch / XGBoost</span>
          <span class="border border-white/10 px-4 py-1.5 rounded-full bg-black/50 backdrop-blur-sm">Kafka / Docker / K8s</span>
          <span class="border border-white/10 px-4 py-1.5 rounded-full bg-black/50 backdrop-blur-sm">LLM APIs / RAG</span>
        </div>
      </div>
    </section>

    <section class="px-8 md:px-16 py-12 relative z-20 -mt-10">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        Latest Releases <span class="text-kiss-accent text-3xl leading-none">›</span>
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </section>

    <section class="px-8 md:px-16 py-16 max-w-6xl">
      <h2 class="text-2xl font-bold mb-10 flex items-center gap-2 border-b border-white/10 pb-4">
        Career Episodes <span class="text-kiss-accent text-3xl leading-none">›</span>
      </h2>
      
      <div class="space-y-12">
        <div class="flex flex-col md:flex-row gap-4 md:gap-12 group">
          <div class="md:w-1/4 text-kiss-text-muted text-sm font-bold pt-1 uppercase tracking-wider group-hover:text-kiss-accent transition-colors">
            May 2025 - Present
          </div>
          <div class="md:w-3/4">
            <h3 class="text-2xl font-bold text-white mb-1">Applied AI Engineer</h3>
            <h4 class="text-kiss-accent font-semibold mb-4 text-lg">Shrive Solutions LLC</h4>
            <ul class="list-none space-y-3 text-gray-400 text-sm leading-relaxed">
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-accent before:rounded-full">Built real-time ML ranking and personalization services (XGBoost + PyTorch) serving 50K users with sub-150ms latency, improving CTR by 27%.</li>
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-accent before:rounded-full">Designed Kafka-based event pipeline processing 50GB/day of telemetry, reducing analytics latency from 6 hours to 10-20 mins.</li>
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-accent before:rounded-full">Built LLM + RAG-based product search system using vector databases, improving search relevance by 35%.</li>
            </ul>
          </div>
        </div>

        <div class="flex flex-col md:flex-row gap-4 md:gap-12 group">
          <div class="md:w-1/4 text-kiss-text-muted text-sm font-bold pt-1 uppercase tracking-wider group-hover:text-kiss-accent transition-colors">
            Sep 2024 - Apr 2025
          </div>
          <div class="md:w-3/4">
            <h3 class="text-2xl font-bold text-white mb-1">Data & Engagement Analyst</h3>
            <h4 class="text-gray-300 font-semibold mb-4 text-lg">Social Media Ministries</h4>
            <ul class="list-none space-y-3 text-gray-400 text-sm leading-relaxed">
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-text-muted before:rounded-full group-hover:before:bg-kiss-accent transition-all">Analyzed Firebase event data to identify churn drivers, contributing to ~60-90% user growth.</li>
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-text-muted before:rounded-full group-hover:before:bg-kiss-accent transition-all">Built personalization system using behavioral signals, increasing DAU by 75%.</li>
            </ul>
          </div>
        </div>

        <div class="flex flex-col md:flex-row gap-4 md:gap-12 group">
          <div class="md:w-1/4 text-kiss-text-muted text-sm font-bold pt-1 uppercase tracking-wider group-hover:text-kiss-accent transition-colors">
            Aug 2023 - May 2024
          </div>
          <div class="md:w-3/4">
            <h3 class="text-2xl font-bold text-white mb-1">Graduate Research Assistant</h3>
            <h4 class="text-gray-300 font-semibold mb-4 text-lg">University of Texas at Arlington</h4>
            <ul class="list-none space-y-3 text-gray-400 text-sm leading-relaxed">
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-text-muted before:rounded-full group-hover:before:bg-kiss-accent transition-all">Built time-series forecasting models (TensorFlow) predicting infrastructure demand, improving capacity planning accuracy by 68%.</li>
              <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-kiss-text-muted before:rounded-full group-hover:before:bg-kiss-accent transition-all">Built ETL pipelines processing 100GB+ telemetry data for feature engineering.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
	<section class="px-8 md:px-16 py-16 mt-8 border-t border-white/10 bg-gradient-to-b from-transparent to-kiss-surface/30">
      <h2 class="text-2xl font-bold mb-10 flex items-center justify-center gap-2">
        Let's Get In Touch <span class="text-kiss-accent text-3xl leading-none">›</span>
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <a href="mailto:taksha.thosani17@gmail.com" class="group flex flex-col items-center justify-center p-8 rounded-xl bg-kiss-surface border border-white/5 hover:-translate-y-2 hover:border-kiss-accent hover:shadow-[0_10px_30px_rgba(255,46,81,0.2)] transition-all duration-300">
          <div class="h-12 w-12 rounded-full bg-white/5 flex items-center justify-center mb-4 group-hover:bg-kiss-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 group-hover:text-kiss-accent transition-colors"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </div>
          <span class="text-sm font-bold text-white mb-1">Email</span>
          <span class="text-xs text-kiss-text-muted text-center break-all">taksha.thosani17@gmail.com</span>
        </a>

        <a href="tel:682-374-5705" class="group flex flex-col items-center justify-center p-8 rounded-xl bg-kiss-surface border border-white/5 hover:-translate-y-2 hover:border-kiss-accent hover:shadow-[0_10px_30px_rgba(255,46,81,0.2)] transition-all duration-300">
          <div class="h-12 w-12 rounded-full bg-white/5 flex items-center justify-center mb-4 group-hover:bg-kiss-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 group-hover:text-kiss-accent transition-colors"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <span class="text-sm font-bold text-white mb-1">Phone</span>
          <span class="text-xs text-kiss-text-muted">682-374-5705</span>
        </a>
        
        <a href="https://linkedin.com/in/taksha-thosani" target="_blank" class="group flex flex-col items-center justify-center p-8 rounded-xl bg-kiss-surface border border-white/5 hover:-translate-y-2 hover:border-kiss-accent hover:shadow-[0_10px_30px_rgba(255,46,81,0.2)] transition-all duration-300">
          <div class="h-12 w-12 rounded-full bg-white/5 flex items-center justify-center mb-4 group-hover:bg-kiss-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 group-hover:text-kiss-accent transition-colors"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </div>
          <span class="text-sm font-bold text-white mb-1">LinkedIn</span>
          <span class="text-xs text-kiss-text-muted">Let's Connect</span>
        </a>

        <a href="https://github.com/taksha17" target="_blank" class="group flex flex-col items-center justify-center p-8 rounded-xl bg-kiss-surface border border-white/5 hover:-translate-y-2 hover:border-kiss-accent hover:shadow-[0_10px_30px_rgba(255,46,81,0.2)] transition-all duration-300">
          <div class="h-12 w-12 rounded-full bg-white/5 flex items-center justify-center mb-4 group-hover:bg-kiss-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 group-hover:text-kiss-accent transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </div>
          <span class="text-sm font-bold text-white mb-1">GitHub</span>
          <span class="text-xs text-kiss-text-muted">View Repositories</span>
        </a>
      </div>
    </section>
	<section class="px-8 md:px-16 py-4 mb-8 max-w-6xl mx-auto">
      <div class="relative overflow-hidden rounded-2xl border border-kiss-accent/30 bg-kiss-surface p-8 shadow-[0_0_30px_rgba(255,46,81,0.05)] group hover:border-kiss-accent/60 transition-all duration-500">
        
        <div class="absolute -top-24 -right-24 h-48 w-48 rounded-full bg-kiss-accent/10 blur-[80px] pointer-events-none group-hover:bg-kiss-accent/20 transition-colors duration-500"></div>
        <div class="absolute -bottom-24 -left-24 h-48 w-48 rounded-full bg-kiss-accent/10 blur-[80px] pointer-events-none group-hover:bg-kiss-accent/20 transition-colors duration-500"></div>

        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          
          <div class="text-center md:text-left">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center justify-center md:justify-start gap-3">
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-kiss-accent opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-kiss-accent"></span>
              </span>
              Actively Looking For Roles
            </h2>
            <p class="text-kiss-text-muted text-sm">Ready to bring high-performance engineering to your next production.</p>
          </div>
          
          <div class="flex flex-wrap justify-center md:justify-end gap-3">
            <span class="px-5 py-2.5 rounded-md border border-white/10 bg-black/50 text-sm font-bold text-white tracking-wide shadow-inner hover:border-kiss-accent hover:text-kiss-accent transition-colors duration-300 cursor-default">
              AI Engineer
            </span>
            <span class="px-5 py-2.5 rounded-md border border-white/10 bg-black/50 text-sm font-bold text-white tracking-wide shadow-inner hover:border-kiss-accent hover:text-kiss-accent transition-colors duration-300 cursor-default">
              ML Engineer
            </span>
            <span class="px-5 py-2.5 rounded-md border border-white/10 bg-black/50 text-sm font-bold text-white tracking-wide shadow-inner hover:border-kiss-accent hover:text-kiss-accent transition-colors duration-300 cursor-default">
              Data Scientist
            </span>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>