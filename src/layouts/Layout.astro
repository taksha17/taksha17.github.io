---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Taksha S. Thosani - Software Engineer & Data Scientist Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        
        <!-- This is where our KissKH Tailwind v4 theme gets loaded -->
		<link rel="stylesheet" href="/src/styles/global.css" />
	</head>
	<body class="bg-kiss-bg text-white font-sans antialiased selection:bg-kiss-accent selection:text-white min-h-screen">
        <!-- The <slot /> is where your index.astro content gets injected -->
		<slot />
	</body>
</html>